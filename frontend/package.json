{
  "name": "wuxing-persona-card-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit -p tsconfig.json && vite build",
    "validate:copy": "node ../scripts/validate-result-content.mjs",
    "validate:star-tone": "node ../scripts/validate-result-content.mjs",
    "validate:result-content": "node ../scripts/validate-result-content.mjs",
    "e2e:mobile": "playwright test e2e/mobile-main-flow.spec.mjs --browser=chromium",
    "e2e:showcase": "playwright test e2e/showcase-screenshots.spec.mjs --browser=chromium",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10"
  }
}
