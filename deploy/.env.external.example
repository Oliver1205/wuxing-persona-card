APP_BASE_URL=https://wuxing.example.com
MYSQL_DATABASE=wuxing_persona
MYSQL_USER=wuxing
MYSQL_PASSWORD=replace-with-strong-wuxing-db-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
REDIS_HOST=redis
REDIS_PORT=6379
ADMIN_TOKEN=replace-with-strong-admin-token
HASH_SALT=replace-with-strong-random-salt
NGINX_HTTP_PORT=80

SHORT_LINK_MODE=external
SHORT_LINK_EXTERNAL_BASE_URL=http://host.docker.internal:8003
SHORT_LINK_EXTERNAL_GROUP_ID=wuxing_persona
SHORT_LINK_EXTERNAL_DOMAIN=s.example.com
SHORT_LINK_EXTERNAL_FALLBACK_TO_INTERNAL=true
SHORT_LINK_EXTERNAL_SYSTEM_USERNAME=wuxing_system
SHORT_LINK_EXTERNAL_SYSTEM_USER_ID=wuxing-system
SHORT_LINK_EXTERNAL_SYSTEM_REAL_NAME=wuxing-system
SHORT_LINK_EXTERNAL_CONNECT_TIMEOUT_MILLIS=2000
SHORT_LINK_EXTERNAL_READ_TIMEOUT_MILLIS=3000
SHORT_LINK_EXTERNAL_STATS_ENABLED=true
SHORT_LINK_EXTERNAL_STATS_ENABLE_STATUS=0
SHORT_LINK_EXTERNAL_STATS_CACHE_TTL_SECONDS=60

# Optional external-service notes consumed by scripts/external-shortlink-preflight.sh.
EXTERNAL_SHORTLINK_PROJECT_DIR=/Users/linyuxiang/JavaBackend/01_Projects/shortlink
EXTERNAL_SHORTLINK_AGGREGATION_PORT=8003
