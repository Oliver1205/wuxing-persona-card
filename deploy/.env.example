APP_BASE_URL=https://your-domain.com
VITE_ICP_RECORD_NO=replace-with-issued-icp-record-no
VITE_ICP_LINK=https://beian.miit.gov.cn/
MYSQL_DATABASE=wuxing_persona
MYSQL_USER=wuxing
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
REDIS_HOST=redis
REDIS_PORT=6379
ADMIN_TOKEN=change-me
HASH_SALT=change-me
NGINX_HTTP_PORT=80

# Optional: keep empty for same-origin Nginx proxy deployment. Set only when
# the frontend and API are served from different origins.
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# CORS_MAX_AGE_SECONDS=3600

SHORT_LINK_MODE=internal
SHORT_LINK_LAST_VISIT_TOUCH_INTERVAL_SECONDS=30
SHORT_LINK_EXTERNAL_BASE_URL=http://shortlink:8003
SHORT_LINK_EXTERNAL_GROUP_ID=wuxing_persona
SHORT_LINK_EXTERNAL_DOMAIN=nurl.ink:8003
SHORT_LINK_EXTERNAL_FALLBACK_TO_INTERNAL=true
SHORT_LINK_EXTERNAL_SYSTEM_USERNAME=wuxing_system
SHORT_LINK_EXTERNAL_SYSTEM_USER_ID=wuxing-system
SHORT_LINK_EXTERNAL_SYSTEM_REAL_NAME=wuxing-system
SHORT_LINK_EXTERNAL_CONNECT_TIMEOUT_MILLIS=2000
SHORT_LINK_EXTERNAL_READ_TIMEOUT_MILLIS=3000
SHORT_LINK_EXTERNAL_STATS_ENABLED=false
SHORT_LINK_EXTERNAL_STATS_ENABLE_STATUS=0
SHORT_LINK_EXTERNAL_STATS_CACHE_TTL_SECONDS=60

VISIT_EVENT_ASYNC_QUEUE_CAPACITY=2048
VISIT_EVENT_ASYNC_DRAIN_LIMIT=64

# Optional: use these only when the server cannot reach Docker Hub directly.
# BACKEND_MAVEN_IMAGE=maven:3.9.9-eclipse-temurin-17
# BACKEND_RUNTIME_IMAGE=eclipse-temurin:17-jre
# FRONTEND_NODE_IMAGE=node:20-alpine
# FRONTEND_NGINX_IMAGE=nginx:1.27-alpine
